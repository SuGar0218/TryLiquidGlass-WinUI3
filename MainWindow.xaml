<?xml version="1.0" encoding="utf-8" ?>
<Window
	x:Class="TryLiquidGlass.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="using:TryLiquidGlass.Controls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="using:TryLiquidGlass"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Title="TryLiquidGlass"
	mc:Ignorable="d">

	<Window.SystemBackdrop>
		<MicaBackdrop />
	</Window.SystemBackdrop>

	<Grid x:Name="PART_RootGrid">
		<Image
			x:Name="PART_Wallpaper"
			Source="/Assets/OS 26 Liquid Glass Sample.jpg"
			Stretch="UniformToFill" />
		<Canvas>
			<controls:LiquidGlassContentControl
				x:Name="PART_LiquidGlassSample"
				Padding="48"
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				BackgroundSource="{x:Bind PART_Wallpaper}"
				BorderThickness="2"
				CornerRadius="32"
				Foreground="White"
				PointerMoved="LiquidGlassContentControl_PointerMoved"
				PointerPressed="LiquidGlassContentControl_PointerPressed"
				PointerReleased="LiquidGlassContentControl_PointerReleased"
				Thickness="16">
				<StackPanel Spacing="8">
					<TextBlock
						HorizontalAlignment="Center"
						Foreground="White"
						Style="{ThemeResource TitleTextBlockStyle}"
						Text="Liquid Glass" />
					<TextBlock
						HorizontalAlignment="Center"
						FontSize="16"
						Foreground="White"
						Opacity="0.5"
						Text="Win2D for WinUI 3" />
					<TextBlock
						HorizontalAlignment="Center"
						FontSize="16"
						Foreground="White"
						Opacity="0.5"
						Text="与君初相识，犹如故人归" />
				</StackPanel>
			</controls:LiquidGlassContentControl>
		</Canvas>
	</Grid>

</Window>
